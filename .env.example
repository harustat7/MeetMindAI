# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meetmind?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
DEV_AUTH_ENABLED="true"

# Email magic-link auth
EMAIL_SERVER=""
EMAIL_FROM="MeetMind AI <noreply@meetmind.ai>"

# Google OAuth and Calendar
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth and Outlook Calendar
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# OpenAI
OPENAI_API_KEY=""
OPENAI_SUMMARY_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# App URLs used by redirects and deployments
APP_URL="http://localhost:3000"
VERCEL_URL=""
VERCEL_ENV="development"

# Logging and monitoring
LOG_LEVEL="info"
SENTRY_DSN=""
