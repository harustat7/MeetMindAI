generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
}

enum MeetingStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum KnowledgeSourceType {
  MEETING
  DOCUMENT
  NOTE
  POLICY
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuditAction {
  WORKSPACE_CREATED
  MEMBER_INVITED
  MEMBER_ROLE_CHANGED
  MEETING_SUMMARIZED
  MEETING_INDEXED
  COMMENT_CREATED
  KNOWLEDGE_CREATED
  SSO_UPDATED
}

enum UsageEventType {
  MEETING_SYNC
  AI_SUMMARY
  AI_CHAT
  VECTOR_INDEX
  KNOWLEDGE_DOCUMENT
  FOLLOW_UP_EMAIL
}

enum SsoProvider {
  OIDC
  SAML
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String?             @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  memberships       WorkspaceMember[]
  calendarAccounts  CalendarAccount[]
  knowledgeDocuments KnowledgeDocument[]
  chatSessions      MeetingChatSession[]
  comments          Comment[]
  meetings          MeetingAttendee[]
  createdMeetings   Meeting[]           @relation("MeetingOwner")
  actionItems        ActionItem[]        @relation("ActionItemAssignee")
  auditLogs         AuditLog[]
  usageEvents       UsageEvent[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Workspace {
  id                  String              @id @default(cuid())
  name                String
  slug                String              @unique
  plan                PlanTier            @default(FREE)
  default             Boolean             @default(false)
  members             WorkspaceMember[]
  meetings            Meeting[]
  knowledgeDocuments  KnowledgeDocument[]
  comments            Comment[]
  auditLogs           AuditLog[]
  usageEvents         UsageEvent[]
  ssoConnections      SsoConnection[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([plan])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId, role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CalendarAccount {
  id                String           @id @default(cuid())
  userId            String
  provider          CalendarProvider
  providerAccountId String
  email             String?
  accessToken       String           @db.Text
  refreshToken      String?          @db.Text
  expiresAt         DateTime?
  syncToken         String?          @db.Text
  lastSyncedAt      DateTime?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings          Meeting[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([provider, providerAccountId])
}

model Meeting {
  id                 String            @id @default(cuid())
  ownerId            String
  workspaceId        String?
  calendarAccountId  String?
  externalId         String?
  provider           CalendarProvider?
  title              String
  description        String?           @db.Text
  location           String?
  conferenceUrl      String?
  startsAt           DateTime
  endsAt             DateTime
  status             MeetingStatus     @default(UPCOMING)
  transcript         Transcript?
  summary            Summary?
  expansion          MeetingExpansion?
  embeddings         MeetingEmbedding[]
  chatSessions       MeetingChatSession[]
  followUpEmails     FollowUpEmail[]
  comments           Comment[]
  attendees          MeetingAttendee[]
  actionItems        ActionItem[]
  owner              User              @relation("MeetingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  workspace          Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  calendarAccount    CalendarAccount?  @relation(fields: [calendarAccountId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([provider, externalId, ownerId])
  @@index([workspaceId, startsAt])
  @@index([ownerId, startsAt])
}

model MeetingAttendee {
  id        String   @id @default(cuid())
  meetingId String
  userId    String?
  name      String?
  email     String?
  response  String?
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([meetingId])
}

model Transcript {
  id         String   @id @default(cuid())
  meetingId  String   @unique
  content    String   @db.Text
  source     String?
  language   String?  @default("en")
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Summary {
  id          String   @id @default(cuid())
  meetingId   String   @unique
  model       String
  executive   String?  @db.Text
  overview    String   @db.Text
  detailed    String?  @db.Text
  decisions   String[] @default([])
  risks       String[] @default([])
  blockers    String[] @default([])
  nextSteps   String[] @default([])
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingExpansion {
  id                   String   @id @default(cuid())
  meetingId            String   @unique
  model                String
  executionPlan        Json
  projectRoadmap       Json
  timeline             Json
  milestones           Json
  resourceRequirements Json
  successMetrics       Json
  meeting              Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ActionItem {
  id          String           @id @default(cuid())
  meetingId   String
  assigneeId  String?
  title       String
  description String?          @db.Text
  dueAt       DateTime?
  status      ActionItemStatus @default(OPEN)
  meeting     Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee    User?            @relation("ActionItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([meetingId])
}

model MeetingEmbedding {
  id          String   @id @default(cuid())
  meetingId   String
  chunkIndex   Int
  content     String   @db.Text
  embedding   Json
  metadata    Json?
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([meetingId, chunkIndex])
  @@index([meetingId])
}

model KnowledgeDocument {
  id          String              @id @default(cuid())
  ownerId     String
  workspaceId String?
  title       String
  sourceType  KnowledgeSourceType @default(DOCUMENT)
  content     String              @db.Text
  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workspace   Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  embeddings  KnowledgeEmbedding[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([ownerId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model KnowledgeEmbedding {
  id          String            @id @default(cuid())
  documentId  String
  chunkIndex  Int
  content     String            @db.Text
  embedding   Json
  metadata    Json?
  document    KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

model MeetingChatSession {
  id        String               @id @default(cuid())
  meetingId String
  userId    String
  title     String?
  meeting   Meeting              @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  MeetingChatMessage[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([meetingId, updatedAt])
  @@index([userId, updatedAt])
}

model MeetingChatMessage {
  id        String             @id @default(cuid())
  sessionId String
  role      ChatRole
  content   String             @db.Text
  citations Json?
  session   MeetingChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())

  @@index([sessionId, createdAt])
}

model FollowUpEmail {
  id        String   @id @default(cuid())
  meetingId String
  subject   String
  body      String   @db.Text
  recipients String[] @default([])
  model     String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([meetingId, updatedAt])
}

model Comment {
  id          String    @id @default(cuid())
  meetingId   String
  workspaceId String?
  authorId    String
  body        String    @db.Text
  resolvedAt  DateTime?
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([meetingId, createdAt])
  @@index([workspaceId, createdAt])
}

model UsageEvent {
  id          String         @id @default(cuid())
  workspaceId String?
  userId      String?
  type        UsageEventType
  quantity    Int            @default(1)
  metadata    Json?
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())

  @@index([workspaceId, type, createdAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      AuditAction
  targetType  String?
  targetId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor       User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([workspaceId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model SsoConnection {
  id             String      @id @default(cuid())
  workspaceId    String
  provider       SsoProvider
  domain         String
  issuer         String?
  clientId       String?
  clientSecret   String?     @db.Text
  metadataUrl    String?
  entryPoint     String?
  certificate    String?     @db.Text
  enabled        Boolean     @default(false)
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([workspaceId, domain])
  @@index([domain, enabled])
}
